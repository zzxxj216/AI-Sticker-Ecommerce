# ============================================================
# AI Sticker Trend Fetcher - 环境变量配置
# 复制此文件为 .env 并填入真实 Key
# ============================================================

# ---- NewsAPI (免费: 100次/天) ----
# 注册地址: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# ---- Reddit API (免费) ----
# 注册地址: https://www.reddit.com/prefs/apps -> Create App (script类型)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# ---- Anthropic Claude API (按量付费, 可选) ----
# 注册地址: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# ---- 目标市场设置 ----
# 支持: united_states, united_kingdom, australia, canada
TREND_GEO=united_states

# ---- 输出设置 ----
OUTPUT_DIR=./output
