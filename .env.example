# ============================================================
# AI Sticker Ecommerce — Environment Variables Template
# Copy to .env and fill in your actual values:
#   cp .env.example .env && nano .env
# ============================================================

# ---- OpenAI API ----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ---- Anthropic Claude API ----
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-20250514

# ---- Google Gemini API ----
IMAGE_API_KEY=
IMAGE_BASE_URL=https://generativelanguage.googleapis.com
IMAGE_MODEL=gemini-2.0-flash-exp
GEMINI_TEXT_MODEL=gemini-2.0-pro-exp

# ---- Shopify Admin API ----
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_BLOG_HANDLE=blog
SHOPIFY_API_VERSION=2024-01

# ---- Feishu (Sticker Bot) ----
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=

# ---- Feishu (Blog Agent Bot) ----
FEISHU_BLOG_APP_ID=
FEISHU_BLOG_APP_SECRET=

# ---- Feishu (Trend Dashboard Bot) ----
# 每日推送目标群 chat_id
FEISHU_TREND_CHAT_ID=
# 多维表格 (可选)
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_URL=
FEISHU_TABLE_NEWS=
FEISHU_TABLE_TK=
FEISHU_TABLE_BRIEFS=
FEISHU_TABLE_HISTORY=

# ---- Feishu H5 Workbench ----
FEISHU_H5_APP_ID=
FEISHU_H5_APP_SECRET=
FEISHU_H5_BASE_URL=http://127.0.0.1:8000
FEISHU_H5_REDIRECT_URI=http://127.0.0.1:8000/auth/feishu/callback
FEISHU_H5_SESSION_SECRET=change-me-to-a-long-random-string

# ---- Agent Storage ----
# AGENT_DB_PATH=./data/agent.db
