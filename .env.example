# ============================================================
# AI Sticker Ecommerce — Environment Variables Template
# Copy to .env and fill in your actual values:
#   cp .env.example .env && nano .env
# ============================================================

# ---- OpenAI API ----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
# 可选：仅用于 scripts/generate_product_reviews_xlsx.py
OPENAI_REVIEW_MODEL=gpt-5.4
# 可选：tests/test_demo_gpt54_pro_reasoning.py — 中转未实现 /v1/responses 时设为 1，直接走 Chat Completions
# OPENAI_USE_CHAT_ONLY=1

# ---- Anthropic Claude API ----
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-20250514

# ---- Google Gemini API ----
IMAGE_API_KEY=
IMAGE_BASE_URL=https://generativelanguage.googleapis.com
IMAGE_MODEL=gemini-2.0-flash-exp
GEMINI_TEXT_MODEL=gemini-2.0-pro-exp

# ---- Shopify Admin API ----
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_BLOG_HANDLE=blog
SHOPIFY_API_VERSION=2024-01
# 可选：导出产品 CSV 时用自定义域名作为前台链接根（默认用 https://SHOPIFY_STORE_DOMAIN）
SHOPIFY_STOREFRONT_BASE_URL=

# ---- Feishu (Sticker Bot) ----
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# ---- Feishu (Blog Agent Bot) ----
FEISHU_BLOG_APP_ID=
FEISHU_BLOG_APP_SECRET=

# ---- Feishu (Trend Dashboard Bot) ----
# 每日推送目标群 chat_id
FEISHU_TREND_CHAT_ID=
# 多维表格 (可选)
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_URL=
FEISHU_TABLE_NEWS=
FEISHU_TABLE_TK=
FEISHU_TABLE_BRIEFS=
FEISHU_TABLE_HISTORY=

# ---- Feishu H5 Workbench ----
FEISHU_H5_APP_ID=
FEISHU_H5_APP_SECRET=
FEISHU_H5_BASE_URL=http://127.0.0.1:8000
FEISHU_H5_REDIRECT_URI=http://127.0.0.1:8000/auth/feishu/callback
FEISHU_H5_SESSION_SECRET=change-me-to-a-long-random-string

# ---- Session / Security ----
SESSION_SECRET=change-me-to-a-long-random-string

# ---- Gemini Concurrency ----
GEMINI_MAX_CONCURRENCY=6

# ---- AiHubMix (联网搜索，用于选品日历) ----
AIHUBMIX_API_KEY=
AIHUBMIX_BASE_URL=https://aihubmix.com/v1/chat/completions
AIHUBMIX_MODEL=gpt-5.4:surfing

# ---- ElevenLabs (视频配音独白 / TTS) ----
# 视频详情页「生成配音独白」用：Gemini 分析视频 → 英文独白 → ElevenLabs 配音 → 烧录字幕。
ELEVENLABS_API_KEY=
# 可选：音色 id（留空用默认 Jessica，免费版可用）。在 ElevenLabs 后台 Voices 复制。
ELEVENLABS_VOICE_ID=
# 可选：模型（默认 eleven_multilingual_v2）
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ---- V2 Daily Sticker Topic Collector ----
# Runs once per day inside the FastAPI APScheduler. Manual runs are available
# from /v2/hot-topics. Time follows the server timezone.
DAILY_STICKER_TOPIC_HOUR=9
DAILY_STICKER_TOPIC_MINUTE=0
DAILY_STICKER_TOPIC_MAX_IMAGE_MB=10

# ---- Blotato API (TikTok / Social Publishing) ----
BLOTATO_API_KEY=
BLOTATO_TK_ACCOUNT_IDS=

# ---- TikTok Display API (OAuth2 / Analytics) ----
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8888/auth/tiktok/callback

# ---- TKShop publishing (multi-channel-api FastAPI service) ----
# multi-channel-api is the sibling project that owns TikTok Shop signing,
# price/warehouse/weight defaults, and the /api/v1/tiktok/products/sticker_publish
# endpoint that this app POSTs into.
TKSHOP_SERVER_URL=http://localhost:8000
# Auto-fix toggle: when true the publish flow asks the AI to rewrite the
# failing payload (title / description / seller_sku) and retries.
TKSHOP_PUBLISH_AUTO_FIX=true
TKSHOP_PUBLISH_MAX_RETRIES=3
# Public base URL the multi-channel-api server uses to fetch our product
# images via the /v2-outputs static mount. Default assumes both services
# run on the same localhost.
TKSHOP_IMAGE_PUBLIC_BASE=http://localhost:5000
# Shops the operator can manage. Comma-separated names that MUST match
# keys in multi-channel-api's TIKTOK_SHOPS_JSON registry. The first one
# is the default for newly-created products and the UI dropdown landing
# value. Single-shop deployments can leave this as 'main' (or omit).
# TIKTOK_SHOPS_JSON. First name is the default landing tab.
TKSHOP_SHOPS=main,second
# AI 商品图：主图默认 medium（与贴纸拆分一致）；并发 1 + 主图优先生成，降低 JieKou 断连
# TKSHOP_MAIN_IMAGE_QUALITY=medium
# TKSHOP_IMAGE_GEN_CONCURRENCY=1
# TKSHOP_MAIN_MERGE_MAX_SIDE=1536
# TKSHOP_MAIN_REF_UPLOAD_MAX_SIDE=1536
# TKSHOP_MAIN_REF_MAX_BYTES=1800000
# PDF/CDR 外部导入：默认用解析图作参考走 image_edit 生成主图；设为 1 则跳过模型、直接白底贴图
# TKSHOP_EXTERNAL_MAIN_DIRECT=0

# ---- Server ----
PORT=8888

# ---- ElevenLabs (视频脚本旁白配音 / TTS) ----
# 在 /v2 视频详情页的脚本卡片上点「生成配音」，朗读每个场景的 caption 生成 mp3。
ELEVENLABS_API_KEY=your_elevenlabs_api_key
# 可选：音色 id（留空用默认英文音色 Rachel）。在 ElevenLabs 后台 Voices 里复制。
ELEVENLABS_VOICE_ID=
# 可选：模型（默认 eleven_multilingual_v2；纯英文想更快更省可用 eleven_turbo_v2_5）
ELEVENLABS_MODEL_ID=eleven_multilingual_v2