# ============================================================
# AI Sticker Generator - 环境变量配置示例
# 复制此文件为 .env 并填入真实的 API Key
# ============================================================

# ---- 环境设置 ----
# 可选值: development, production
ENV=development

# ---- Claude API (必需) ----
# 注册地址: https://console.anthropic.com
ANTHROPIC_API_KEY=your-claude-api-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com

# 可选：指定模型
# CLAUDE_MODEL=claude-opus-4.6

# ---- Gemini API (必需) ----
# 注册地址: https://aistudio.google.com/apikey
IMAGE_API_KEY=your-gemini-api-key-here
IMAGE_BASE_URL=https://generativelanguage.googleapis.com

# 可选：指定模型
# IMAGE_MODEL=gemini-3.1-flash-image-preview

# ---- 飞书 Bot (可选, 接入飞书时必需) ----
# 在飞书开放平台创建应用后获取: https://open.feishu.cn
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
# Verification Token — 事件订阅页面获取
FEISHU_VERIFICATION_TOKEN=your-verification-token
# Encrypt Key — 可选，开启加密时填写
# FEISHU_ENCRYPT_KEY=your-encrypt-key

# ---- 输出目录 (可选) ----
# OUTPUT_DIR=./data/output
# CACHE_DIR=./data/cache
# TEMP_DIR=./data/temp

# ---- 日志配置 (可选) ----
# LOG_LEVEL=INFO
# LOG_DIR=./logs
